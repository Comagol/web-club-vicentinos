generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  SOCIO
  SUBCOMISION
  COMISION_DIRECTIVA
  EMPLEADO
  JEFE_AREA
  ADMIN
  ENCARGADO_BOUTIQUE
}

enum EstadoMembresia {
  ACTIVO
  INACTIVO
  MOROSO
}

enum AreaOperativa {
  MANTENIMIENTO
  LIMPIEZA
  SEGURIDAD
}

model Usuario {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  roles    UsuarioRol[]
  socio    Socio?
  empleado Empleado?
}

model UsuarioRol {
  id        String @id @default(uuid())
  usuarioId String
  rol       Rol

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, rol])
}

model CategoriaSocio {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?

  socios  Socio[]
  tarifas TarifaCuota[]
}

model Socio {
  id               String          @id @default(uuid())
  usuarioId        String?         @unique
  numeroSocio      String          @unique
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  fotoUrl          String?
  categoriaSocioId String
  tutorId          String?
  estadoMembresia  EstadoMembresia @default(ACTIVO)
  tokenQr          String          @unique @default(uuid())

  usuario        Usuario?       @relation(fields: [usuarioId], references: [id])
  categoriaSocio CategoriaSocio @relation(fields: [categoriaSocioId], references: [id])
  tutor          Socio?         @relation("TutorMenor", fields: [tutorId], references: [id])
  tutelados      Socio[]        @relation("TutorMenor")

  gruposFamiliares       GrupoFamiliarMiembro[]
  divisionesPorTemporada SocioDivisionTemporada[]
  subcomisiones          SubcomisionMiembro[]
  cuotas                 Cuota[]
  mediosPago             MedioPagoAdherido[]
}

enum TipoGrupoFamiliar {
  MATRIMONIO
}

model GrupoFamiliar {
  id   String            @id @default(uuid())
  tipo TipoGrupoFamiliar

  miembros GrupoFamiliarMiembro[]
}

model GrupoFamiliarMiembro {
  id              String @id @default(uuid())
  grupoFamiliarId String
  socioId         String

  grupoFamiliar GrupoFamiliar @relation(fields: [grupoFamiliarId], references: [id])
  socio         Socio         @relation(fields: [socioId], references: [id])

  @@unique([grupoFamiliarId, socioId])
}

model Empleado {
  id        String        @id @default(uuid())
  usuarioId String        @unique
  nombre    String
  apellido  String
  area      AreaOperativa

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

enum Deporte {
  RUGBY
  HOCKEY
}

enum NivelDivision {
  INFANTILES
  JUVENILES
  PLANTEL_SUPERIOR
}

enum TiraHockey {
  A
  B
  C
}

model Division {
  id        String        @id @default(uuid())
  deporte   Deporte
  categoria String
  nivel     NivelDivision
  tira      TiraHockey?

  asignaciones SocioDivisionTemporada[]

  @@unique([deporte, categoria, tira])
}

model Temporada {
  id   String @id @default(uuid())
  anio Int    @unique

  asignaciones SocioDivisionTemporada[]
}

model SocioDivisionTemporada {
  id              String   @id @default(uuid())
  socioId         String
  divisionId      String
  temporadaId     String
  fechaAsignacion DateTime @default(now())

  socio     Socio     @relation(fields: [socioId], references: [id])
  division  Division  @relation(fields: [divisionId], references: [id])
  temporada Temporada @relation(fields: [temporadaId], references: [id])

  @@unique([socioId, divisionId, temporadaId])
}

model Subcomision {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?
  activa      Boolean @default(true)

  miembros    SubcomisionMiembro[]
}

model SubcomisionMiembro {
  id            String   @id @default(uuid())
  subcomisionId String
  socioId       String
  fechaAlta     DateTime @default(now())

  subcomision Subcomision @relation(fields: [subcomisionId], references: [id])
  socio       Socio       @relation(fields: [socioId], references: [id])

  @@unique([subcomisionId, socioId])
}

enum MetodoCuota {
  DEBITO_AUTOMATICO
  MANUAL
  MERCADO_PAGO
}

enum EstadoCuota {
  PENDIENTE
  PAGADA
  VENCIDA
}

enum TipoMedioPago {
  CBU
  TARJETA
}

enum EstadoPagoMP {
  PENDIENTE
  APROBADO
  RECHAZADO
  REEMBOLSADO
}

model TarifaCuota {
  id               String    @id @default(uuid())
  categoriaSocioId String
  monto            Decimal
  vigenteDesde      DateTime
  vigenteHasta      DateTime?

  categoriaSocio CategoriaSocio @relation(fields: [categoriaSocioId], references: [id])
}

model Cuota {
  id              String      @id @default(uuid())
  socioId         String
  mes             Int
  anio            Int
  monto           Decimal
  estado          EstadoCuota @default(PENDIENTE)
  fechaVencimiento DateTime
  fechaPago        DateTime?
  metodo          MetodoCuota?

  socio          Socio           @relation(fields: [socioId], references: [id])
  pagoMercadoPago PagoMercadoPago?

  @@unique([socioId, mes, anio])
}

model MedioPagoAdherido {
  id             String        @id @default(uuid())
  socioId        String
  tipo           TipoMedioPago
  datoEnmascarado String
  activo         Boolean       @default(true)

  socio Socio @relation(fields: [socioId], references: [id])
}

model ArchivoDebito {
  id              String   @id @default(uuid())
  mes             Int
  anio            Int
  fechaGeneracion DateTime @default(now())
  urlArchivo      String
  generadoPor     String

  rendiciones ArchivoRendicion[]

  @@unique([mes, anio])
}

model ArchivoRendicion {
  id                 String    @id @default(uuid())
  archivoDebitoId    String
  fechaSubida        DateTime  @default(now())
  subidoPor          String
  procesado          Boolean   @default(false)
  fechaProcesamiento DateTime?

  archivoDebito ArchivoDebito @relation(fields: [archivoDebitoId], references: [id])
}

model PagoMercadoPago {
  id              String       @id @default(uuid())
  cuotaId         String?      @unique
  pedidoId        String?      @unique
  mpPaymentId     String       @unique
  monto           Decimal
  estado          EstadoPagoMP @default(PENDIENTE)
  fechaCreacion   DateTime     @default(now())
  fechaActualizacion DateTime  @updatedAt
  rawResponse     Json?

  cuota  Cuota?  @relation(fields: [cuotaId], references: [id])
}
