generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  SOCIO
  SUBCOMISION
  COMISION_DIRECTIVA
  EMPLEADO
  JEFE_AREA
  ADMIN
  ENCARGADO_BOUTIQUE
}

enum EstadoMembresia {
  ACTIVO
  INACTIVO
  MOROSO
}

enum AreaOperativa {
  MANTENIMIENTO
  LIMPIEZA
  SEGURIDAD
}

model Usuario {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  roles    UsuarioRol[]
  socio    Socio?
  empleado Empleado?

  solicitudesCreadas  Solicitud[] @relation("SolicitudCreador")
  solicitudesResueltas Solicitud[] @relation("SolicitudResolutor")

  tareasCreadas    Tarea[]
  tareaHistoriales TareaHistorial[]

  noticias Noticia[]
}

model UsuarioRol {
  id        String @id @default(uuid())
  usuarioId String
  rol       Rol

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, rol])
}

model CategoriaSocio {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?

  socios  Socio[]
  tarifas TarifaCuota[]
}

model Socio {
  id               String          @id @default(uuid())
  usuarioId        String?         @unique
  numeroSocio      String          @unique
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  fotoUrl          String?
  categoriaSocioId String
  tutorId          String?
  estadoMembresia  EstadoMembresia @default(ACTIVO)
  tokenQr          String          @unique @default(uuid())

  usuario        Usuario?       @relation(fields: [usuarioId], references: [id])
  categoriaSocio CategoriaSocio @relation(fields: [categoriaSocioId], references: [id])
  tutor          Socio?         @relation("TutorMenor", fields: [tutorId], references: [id])
  tutelados      Socio[]        @relation("TutorMenor")

  gruposFamiliares       GrupoFamiliarMiembro[]
  divisionesPorTemporada SocioDivisionTemporada[]
  subcomisiones          SubcomisionMiembro[]
  cuotas                 Cuota[]
  mediosPago             MedioPagoAdherido[]
  solicitudes            Solicitud[]
  inscripciones          InscripcionActividad[]
  pedidos                Pedido[]
}

enum TipoGrupoFamiliar {
  MATRIMONIO
}

model GrupoFamiliar {
  id   String            @id @default(uuid())
  tipo TipoGrupoFamiliar

  miembros GrupoFamiliarMiembro[]
}

model GrupoFamiliarMiembro {
  id              String @id @default(uuid())
  grupoFamiliarId String
  socioId         String

  grupoFamiliar GrupoFamiliar @relation(fields: [grupoFamiliarId], references: [id])
  socio         Socio         @relation(fields: [socioId], references: [id])

  @@unique([grupoFamiliarId, socioId])
}

model Empleado {
  id        String        @id @default(uuid())
  usuarioId String        @unique
  nombre    String
  apellido  String
  area      AreaOperativa

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  tareasAsignadas Tarea[]
}

enum Deporte {
  RUGBY
  HOCKEY
}

enum NivelDivision {
  INFANTILES
  JUVENILES
  PLANTEL_SUPERIOR
}

enum TiraHockey {
  A
  B
  C
}

model Division {
  id        String        @id @default(uuid())
  deporte   Deporte
  categoria String
  nivel     NivelDivision
  tira      TiraHockey?

  asignaciones SocioDivisionTemporada[]
  resultados   Resultado[]

  @@unique([deporte, categoria, tira])
}

model Temporada {
  id   String @id @default(uuid())
  anio Int    @unique

  asignaciones SocioDivisionTemporada[]
  resultados   Resultado[]
}

model SocioDivisionTemporada {
  id              String   @id @default(uuid())
  socioId         String
  divisionId      String
  temporadaId     String
  fechaAsignacion DateTime @default(now())

  socio     Socio     @relation(fields: [socioId], references: [id])
  division  Division  @relation(fields: [divisionId], references: [id])
  temporada Temporada @relation(fields: [temporadaId], references: [id])

  @@unique([socioId, divisionId, temporadaId])
}

model Subcomision {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?
  activa      Boolean @default(true)

  miembros    SubcomisionMiembro[]
  solicitudes Solicitud[]
  actividades ActividadRecaudatoria[]
}

model SubcomisionMiembro {
  id            String   @id @default(uuid())
  subcomisionId String
  socioId       String
  fechaAlta     DateTime @default(now())

  subcomision Subcomision @relation(fields: [subcomisionId], references: [id])
  socio       Socio       @relation(fields: [socioId], references: [id])

  @@unique([subcomisionId, socioId])
}

enum MetodoCuota {
  DEBITO_AUTOMATICO
  MANUAL
  MERCADO_PAGO
}

enum EstadoCuota {
  PENDIENTE
  PAGADA
  VENCIDA
}

enum TipoMedioPago {
  CBU
  TARJETA
}

enum EstadoPagoMP {
  PENDIENTE
  APROBADO
  RECHAZADO
  REEMBOLSADO
}

model TarifaCuota {
  id               String    @id @default(uuid())
  categoriaSocioId String
  monto            Decimal
  vigenteDesde      DateTime
  vigenteHasta      DateTime?

  categoriaSocio CategoriaSocio @relation(fields: [categoriaSocioId], references: [id])
}

model Cuota {
  id              String      @id @default(uuid())
  socioId         String
  mes             Int
  anio            Int
  monto           Decimal
  estado          EstadoCuota @default(PENDIENTE)
  fechaVencimiento DateTime
  fechaPago        DateTime?
  metodo          MetodoCuota?

  socio          Socio           @relation(fields: [socioId], references: [id])
  pagoMercadoPago PagoMercadoPago?

  @@unique([socioId, mes, anio])
}

model MedioPagoAdherido {
  id             String        @id @default(uuid())
  socioId        String
  tipo           TipoMedioPago
  datoEnmascarado String
  activo         Boolean       @default(true)

  socio Socio @relation(fields: [socioId], references: [id])
}

model ArchivoDebito {
  id              String   @id @default(uuid())
  mes             Int
  anio            Int
  fechaGeneracion DateTime @default(now())
  urlArchivo      String
  generadoPor     String

  rendiciones ArchivoRendicion[]

  @@unique([mes, anio])
}

model ArchivoRendicion {
  id                 String    @id @default(uuid())
  archivoDebitoId    String
  fechaSubida        DateTime  @default(now())
  subidoPor          String
  procesado          Boolean   @default(false)
  fechaProcesamiento DateTime?

  archivoDebito ArchivoDebito @relation(fields: [archivoDebitoId], references: [id])
}

model PagoMercadoPago {
  id              String       @id @default(uuid())
  cuotaId         String?      @unique
  pedidoId        String?      @unique
  mpPaymentId     String       @unique
  monto           Decimal
  estado          EstadoPagoMP @default(PENDIENTE)
  fechaCreacion   DateTime     @default(now())
  fechaActualizacion DateTime  @updatedAt
  rawResponse     Json?

  cuota  Cuota?  @relation(fields: [cuotaId], references: [id])
  pedido Pedido? @relation(fields: [pedidoId], references: [id])
}

enum OrigenSolicitud {
  SOCIO
  SUBCOMISION
}

enum TipoSolicitud {
  RESERVA_ESPACIO
  ACTIVIDAD_RECAUDATORIA
}

enum EstadoSolicitud {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum UsoEspacio {
  PERSONAL
  INSTITUCIONAL
}

enum EstadoPagoInscripcion {
  PENDIENTE
  PAGADO
  NO_APLICA
}

model Solicitud {
  id                   String          @id @default(uuid())
  origen               OrigenSolicitud
  tipo                 TipoSolicitud
  creadoPorUsuarioId   String
  socioId              String?
  subcomisionId        String?
  estado               EstadoSolicitud @default(PENDIENTE)
  notaRechazo          String?
  resueltoPorUsuarioId String?
  fechaSolicitud       DateTime        @default(now())
  fechaResolucion      DateTime?
  solicitudPadreId     String?         @unique

  creadoPor   Usuario      @relation("SolicitudCreador", fields: [creadoPorUsuarioId], references: [id])
  resueltoPor Usuario?     @relation("SolicitudResolutor", fields: [resueltoPorUsuarioId], references: [id])
  socio       Socio?       @relation(fields: [socioId], references: [id])
  subcomision Subcomision? @relation(fields: [subcomisionId], references: [id])
  solicitudPadre Solicitud? @relation("SolicitudReenvio", fields: [solicitudPadreId], references: [id])
  reenvio        Solicitud? @relation("SolicitudReenvio")

  reservaEspacio       ReservaEspacio?
  actividadRecaudatoria ActividadRecaudatoria?
}

model Espacio {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?
  capacidad   Int?
  activo      Boolean @default(true)

  reservas ReservaEspacio[]
}

model ReservaEspacio {
  id          String     @id @default(uuid())
  solicitudId String     @unique
  espacioId   String
  fecha       DateTime
  horaInicio  String
  horaFin     String
  uso         UsoEspacio

  solicitud Solicitud @relation(fields: [solicitudId], references: [id])
  espacio   Espacio   @relation(fields: [espacioId], references: [id])
}

model ActividadRecaudatoria {
  id            String   @id @default(uuid())
  solicitudId   String   @unique
  subcomisionId String
  nombre        String
  descripcion   String?
  fecha         DateTime
  cupo          Int?
  precio        Decimal?

  solicitud   Solicitud   @relation(fields: [solicitudId], references: [id])
  subcomision Subcomision @relation(fields: [subcomisionId], references: [id])
  inscripciones InscripcionActividad[]
}

model InscripcionActividad {
  id               String                @id @default(uuid())
  actividadId      String
  socioId          String
  fechaInscripcion DateTime              @default(now())
  estadoPago       EstadoPagoInscripcion @default(NO_APLICA)

  actividad ActividadRecaudatoria @relation(fields: [actividadId], references: [id])
  socio     Socio                 @relation(fields: [socioId], references: [id])

  @@unique([actividadId, socioId])
}

enum EstadoTarea {
  PENDIENTE
  EN_PROCESO
  CON_LIMITANTE
  FINALIZADO
}

model Tarea {
  id                 String        @id @default(uuid())
  area               AreaOperativa
  titulo             String
  descripcion        String?
  asignadoAEmpleadoId String
  creadoPorUsuarioId String
  estado             EstadoTarea   @default(PENDIENTE)
  notaLimitante      String?
  fechaCreacion      DateTime      @default(now())
  fechaActualizacion DateTime      @updatedAt

  asignadoA Empleado @relation(fields: [asignadoAEmpleadoId], references: [id])
  creadoPor Usuario  @relation(fields: [creadoPorUsuarioId], references: [id])
  historial TareaHistorial[]
}

model TareaHistorial {
  id             String      @id @default(uuid())
  tareaId        String
  estadoAnterior EstadoTarea
  estadoNuevo    EstadoTarea
  usuarioId      String
  fecha          DateTime    @default(now())
  comentario     String?

  tarea   Tarea   @relation(fields: [tareaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

enum EstadoPedido {
  PENDIENTE_PAGO
  PAGADO
  PREPARANDO
  LISTO_PARA_RETIRAR
  ENTREGADO
  CANCELADO
}

enum MetodoPagoPedido {
  EFECTIVO
  MERCADO_PAGO
}

model Producto {
  id          String  @id @default(uuid())
  nombre      String
  descripcion String?
  categoria   String?
  imagenUrl   String?
  activo      Boolean @default(true)

  variantes VarianteProducto[]
}

model VarianteProducto {
  id         String  @id @default(uuid())
  productoId String
  talla      String?
  color      String?
  precio     Decimal
  stock      Int     @default(0)

  producto Producto    @relation(fields: [productoId], references: [id])
  items    ItemPedido[]

  @@unique([productoId, talla, color])
}

model Pedido {
  id         String           @id @default(uuid())
  socioId    String
  fecha      DateTime         @default(now())
  metodoPago MetodoPagoPedido
  estado     EstadoPedido     @default(PENDIENTE_PAGO)
  total      Decimal

  socio           Socio            @relation(fields: [socioId], references: [id])
  items           ItemPedido[]
  pagoMercadoPago PagoMercadoPago?
}

model ItemPedido {
  id                 String  @id @default(uuid())
  pedidoId           String
  varianteProductoId String
  cantidad           Int
  precioUnitario     Decimal

  pedido           Pedido           @relation(fields: [pedidoId], references: [id])
  varianteProducto VarianteProducto @relation(fields: [varianteProductoId], references: [id])
}

enum CondicionPartido {
  LOCAL
  VISITANTE
}

model Noticia {
  id               String   @id @default(uuid())
  titulo           String
  contenido        String
  imagenUrl        String?
  autorUsuarioId   String
  fechaPublicacion DateTime @default(now())
  publicado        Boolean  @default(false)

  autor Usuario @relation(fields: [autorUsuarioId], references: [id])
}

model Resultado {
  id             String           @id @default(uuid())
  divisionId     String
  temporadaId    String
  rival          String
  fecha          DateTime
  condicion      CondicionPartido
  resultadoPropio Int
  resultadoRival  Int

  division  Division  @relation(fields: [divisionId], references: [id])
  temporada Temporada @relation(fields: [temporadaId], references: [id])
}
